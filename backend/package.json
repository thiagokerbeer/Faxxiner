{
  "name": "faxxiner-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "free-port": "node scripts/free-port.mjs",
    "dev": "node scripts/free-port.mjs && node --watch-path=./src --import tsx src/index.ts",
    "build": "prisma generate && node scripts/run-tsc.mjs",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:generate:fresh": "node scripts/prisma-fresh.mjs",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.5.0",
    "typescript": "~5.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "vitest": "^4.1.3"
  }
}
