DATABASE_URL="postgresql://faxxiner:faxxiner_local@localhost:5433/faxxiner?schema=public"
# Em produção: mínimo 32 caracteres aleatórios (obrigatório se NODE_ENV=production)
JWT_SECRET="troque-por-um-segredo-longo-em-producao"
# Duração do token JWT (ex.: 7d, 24h, 3600)
JWT_EXPIRES_IN=7d
# Custo bcrypt (10–15; padrão 12)
BCRYPT_ROUNDS=12
PORT=4002
# Origens CORS (separadas por vírgula). Ex.: http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# Atrás de reverse proxy (nginx, Railway, etc.) — necessário para rate limit por IP correto
# TRUST_PROXY=1
# LGPD — e-mails exibidos em /api/legal/lgpd e na página de privacidade
# LGPD_CONTROLLER_EMAIL=contato@suaempresa.com
# LGPD_DPO_EMAIL=
# Limite de requisições (opcional)
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_REGISTER_MAX=5
